{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "npm: start",
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^(?!.*)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Server address:.*",
          "endsPattern": ".*Server running.*"
        }
      }
    },
    {
      "label": "npm: validate:library",
      "type": "npm",
      "script": "validate:library",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "revealProblems": "onProblem",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
