            "    <h${1:Your heading Level|2,3,4,5,6|} class=\"usa-accordion__heading\">",
            "        <button id=\"accordion-1-title\" type=\"button\" class=\"usa-accordion__button\" aria-expanded=\"true\" aria-controls=\"a1\">${2:Accordion 1 title}</button>",
            "    </h${1}>",
            "    <div id=\"a1\" class=\"usa-accordion__content\">",
            "        ${3:Accordion 1 body}",
            "    </div>",

            "    <h${1} class=\"usa-accordion__heading\">",
            "        <button id=\"accordion-2-title\" type=\"button\" class=\"usa-accordion__button\" aria-expanded=\"true\" aria-controls=\"a2\">${4:Accordion 2 title}</button>",
