            "        ${5:Accordion 2 body}",
            "    </div>",

            "    <h${1} class=\"usa-accordion__heading\">",
            "        <button id=\"accordion-3-title\" type=\"button\" class=\"usa-accordion__button\" aria-expanded=\"true\" aria-controls=\"a3\">${6:Accordion 3 title}</button>",
            "    </h${1}>",
            "    <div id=\"a3\" class=\"usa-accordion__content\">",
            "        ${7:Accordion 3 body}",
            "    </div>",

            "    <h${1} class=\"usa-accordion__heading\">",
            "        <button id=\"accordion-4-title\" type=\"button\" class=\"usa-accordion__button\" aria-expanded=\"true\" aria-controls=\"a4\">${8:Accordion 4 title}</button>",
            "    </h${1}>",
            "    <div id=\"a4\" class=\"usa-accordion__content\">",
            "        ${9:Accordion 4 body}",
