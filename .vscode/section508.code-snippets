    // Images -------------------------------------------------------------------
    "Image Block": {
        "scope": "markdown,html",
        "prefix": "image-block",
        "body": [
            "<div class=\"tablet:grid-col\" style=\"margin: auto; max-width: 100%; text-align: center; padding: 10px 0px\">",
            "    <div class=\"margin-top-1\"><img src=\"{{site.baseurl}}/assets/images/${1:path}/${2:file-name.jpg}\" alt=\"${3:ALT text}\" aria-describedby=\"figure-${4:figure number}\" class=\"border-2px border-base-light shadow-2 padding-1\"></div>",
            "    <div class=\"font-mono-3xs margin-x-auto auto\" style=\"max-width: 90%; text-align: center;\"><span id=\"figure-$4\"><strong>Figure $4.</strong> ${5:Caption text}.</span></div>",
            "</div>",
            "$0",
        ],
        "description": "Create an Section508.gov image block with caption and figure number"
    },    

    // Links -------------------------------------------------------------------
    "Internal Link MD": {
        "scope": "markdown,html",
        "prefix": "link-md",
        "body": [
            "[${1:Link text}]({{site.baseurl}}/${2:path/to/page/})$0"
        ],
        "description": "Create an internal Section508.gov link in markdown"
    },

    "Internal Link HTML": {
        "scope": "markdown,html",
        "prefix": "link-html",
        "body": [
            "<a href=\"{{site.baseurl}}/${1:path/to/page/}\">${2:Link text}</a>$0"
        ],
        "description": "Create an internal Section508.gov link in html"
    },

    "External Link": {
        "scope": "markdown,html",
        "prefix": "link-external",
        "body": [
            "<a href=\"${1:https://example.com}\" class=\"usa-link usa-link--external\" target=\"_blank\" rel=\"noopener\">${2:Link text}</a>$0"
        ],
        "description": "Create an external link"
    },

    "File Assets Link": {
        "scope": "markdown,html",
        "prefix": "link-file",
        "body": [
            "<a href=\"${1:Paste Cloud.gov Pages PFS URL here}\" download>${2:Document title (PDF)}</a>$0"
        ],
        "description": "Create a file download link"
    },

    "Email Link": {
        "scope": "markdown,html",
        "prefix": "link-email",
        "body": [
            "<a href=\"mailto:${1:first.last@domain.com}\">${2:Email link text}</a>$0"
        ],
        "description": "Create an email link"
    },
    
    // Summary Boxes ------------------------------------------------------------
    "Summary Box": {
        "scope": "markdown,html",
        "prefix": "summary-box-small",
        "body": [
            "<div class=\"grid-col-12 ${1|summary-box,summary-box--alt,summary-box--code,summary-box--left,summary-box--right|}\">",
            "    ${2:Your text here}",
            "</div>",
            "$0"
        ],
        "description": "Create and style the default Section508.gov summary box"
    },

    "Callout Box Dual": {
        "scope": "markdown,html",
        "prefix": "summary-box-dual",
        "body": [
            "<div class=\"${1|callout-box-dual,callout-box-dual-alt,callout-box-dual-green,callout-box-dual-violet,callout-box-dual-violet-reverse|} margin-bottom-1\">",
            "    <h${2:Select your heading level|2,3,4,5,6|}>${3:Your heading here}</h$2>",
            "    ${4:Your text here}",
            "</div>",
            "$0"
        ],
        "description": "Create a Section508.gov dual border callout box"
    },

// Accordions
    "Accordion Controls": {
        "scope": "markdown,html",
        "prefix": "accordion-controls",
        "body": [
            "<div class=\"margin-bottom-3\">",
            "    <button id=\"expand-all\" class=\"usa-button\" data-target=\"accordion-group-${1:Set Group Letter|a,b,c,d,e|}\" data-action=\"expand\">Expand All</button>",
            "    <button id=\"collapse-all\" class=\"usa-button\" data-target=\"accordion-group-${1:Group Letter|a,b,c,d,e|}\" data-action=\"collapse\">Collapse All</button>",
            "</div>",
            "$0"
        ],
        "description": "Create Section508.gov accordion expand and collapse controls, allows comma separated group letters to control multiple accordion groups"
    },
    
    "Accordion Group (A:1/3)": {
