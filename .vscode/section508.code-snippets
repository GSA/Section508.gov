            "    <h${1} class=\"usa-accordion__heading\">",
            "        <button id=\"accordion-5-title\" type=\"button\" class=\"usa-accordion__button\" aria-expanded=\"true\" aria-controls=\"a5\">${10:Accordion 5 title}</button>",
