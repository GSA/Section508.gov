{
  "defaults": {
    "concurrency": 1,
    "standard": "WCAG2AA",
    "runners": ["axe", "htmlcs"],
    "ignore": [
      "frame-tested",
      "video-caption",
      "color-contrast"
    ],
    "hideElements": [
      "#how-official, #site-nav, #sec-nav, #sICT, #create-cards, nav li a, nav li span"
    ],
    "timeout": 15000,
    "reporters": [
        "cli",
        ["json", {
          "output": "pa11y-ci-results.json"
        }]
    ]
  }
}